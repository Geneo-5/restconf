# Exemple de configuration nginx pour exposer restconfd (RFC 8040 / RFC 8527)
# via FastCGI. A adapter (TLS, auth, chemins) avant tout usage reel :
# RFC 8040 SS2 impose HTTPS/TLS comme transport obligatoire.
#
# Point important : fastcgi_split_path_info doit isoler la racine
# {+restconf} (ici "/restconf") dans SCRIPT_NAME et le reste du chemin
# dans PATH_INFO, car c'est PATH_INFO que lit restconfd (src/http.c).

events {}
http {
    server {
        listen 80;

        # Decouverte de la racine RESTCONF (RFC 8040 SS3.1).
        location = /.well-known/host-meta {
            fastcgi_param SCRIPT_NAME "";
            fastcgi_param PATH_INFO   "/.well-known/host-meta";
            fastcgi_pass  localhost:9000;
        }

        location /restconf {
            # Isole "/restconf" (SCRIPT_NAME) du reste (PATH_INFO).
            fastcgi_split_path_info ^(/restconf)(/.*)?$;

            fastcgi_param SCRIPT_NAME  $fastcgi_script_name;
            fastcgi_param PATH_INFO    $fastcgi_path_info;
            fastcgi_param QUERY_STRING $query_string;

            fastcgi_pass localhost:9000;

            # RESTCONF n'utilise pas le cache HTTP standard (RFC 8040 SS5.5) ;
            # le serveur applicatif emet deja Cache-Control: no-cache.
            fastcgi_hide_header X-Powered-By;

            # Notifications SSE (RFC 8040 SS3.8/SS6, /restconf/streams/<module>) :
            # restconfd emet deja "X-Accel-Buffering: no" pour ces reponses
            # precises (cf. http_sse_send_headers() dans src/http.c), mais
            # fastcgi_buffering doit AUSSI etre desactive cote nginx pour que
            # les evenements soient transmis au fil de l'eau plutot que
            # retenus jusqu'a la fermeture (qui n'arrive jamais) de la reponse.
            # Decommenter si votre nginx ne respecte pas X-Accel-Buffering :
            # fastcgi_buffering off;
            # fastcgi_read_timeout 1h;
        }
    }
}
